# Database
# Local dev: a local Postgres (citext extension required).
#   postgresql://postgres:postgres@localhost:5432/koos
# Production: any cloud Postgres (Neon / Aiven / Vercel Postgres).
DATABASE_URL=

# Migrations (drizzle-kit). Optional — falls back to DATABASE_URL if unset.
# Use a direct (non-pooled) connection in production if your provider pools.
DIRECT_URL=

# Auth — Google OAuth (sign in with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage — Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public/custom domain that serves objects in the bucket (used for logo URLs).
#   e.g. https://assets.yourdomain.com  or  https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# AI provider (provider-agnostic via the Vercel AI SDK)
# Pick the active provider + model for the whole app:
#   AI_PROVIDER one of: google | zai | openai | anthropic | bedrock | openai-compatible
AI_PROVIDER=google
AI_MODEL=gemini-2.5-flash
# Optional per-feature overrides (fall back to AI_PROVIDER/AI_MODEL):
#   AI_CHAT_PROVIDER=    AI_CHAT_MODEL=
#   AI_STRATEGY_PROVIDER=anthropic   AI_STRATEGY_MODEL=claude-sonnet-4-5
#
# Provide the key for whichever provider(s) you use:
ZAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Generic OpenAI-compatible endpoint (other Chinese models, gateways, etc.)
# Used only when a provider above is set to "openai-compatible".
AI_COMPATIBLE_BASE_URL=
AI_COMPATIBLE_API_KEY=
AI_COMPATIBLE_NAME=

# ── Amazon Bedrock (optional AI provider) ─────────────────────────────
# To route AI through Amazon Bedrock, set AI_PROVIDER=bedrock (or a per-feature
# override like AI_CHAT_PROVIDER=bedrock) and provide the exact model id /
# inference-profile id enabled in your AWS account (there is NO default):
#   AI_PROVIDER=bedrock
#   AI_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0   # example — use YOUR enabled model
# Bedrock authenticates with AWS credentials (not an API key):
#   AWS_REGION=us-east-1
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_SESSION_TOKEN=...        # optional, only for temporary STS credentials
# The IAM principal needs bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream,
# and the model must be enabled in the Bedrock console (Model access) in that region.

# Zoho Mail
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_MAIL_FROM=

# Design team inbox that receives new design-request notifications.
# Optional — falls back to ZOHO_MAIL_FROM / ZOHO_SMTP_USER.
DESIGN_TEAM_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
